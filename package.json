{
    "name": "cypress-xray-plugin",
    "version": "9.0.0",
    "description": "A Cypress plugin for uploading test results to Xray (test management for Jira)",
    "types": "index.d.ts",
    "author": "csvtuda",
    "repository": {
        "type": "git",
        "url": "https://github.com/Qytera-Gmbh/cypress-xray-plugin"
    },
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/Qytera-Gmbh/cypress-xray-plugin/issues"
    },
    "homepage": "https://qytera-gmbh.github.io/projects/cypress-xray-plugin",
    "keywords": [
        "cypress",
        "xray",
        "upload",
        "screenshot",
        "video",
        "cucumber"
    ],
    "files": [
        "src",
        "*.js",
        "*.ts"
    ],
    "exports": {
        ".": "./index.js",
        "./commands": "./src/tasks/commands.js",
        "./commands/tasks": "./src/tasks/index.js"
    },
    "directories": {
        "lib": "src"
    },
    "scripts": {
        "test": "node --import tsx ./test/run-unit-tests.ts",
        "test:coverage": "npx shx mkdir -p coverage && c8 --config .c8.json npm run test",
        "test:integration": "node --import tsx ./test/run-integration-tests.ts",
        "test:server": "node --import tsx ./test/run-server.ts",
        "build": "node --import tsx build.ts",
        "eslint": "eslint src/**/*.ts test/**/*.ts index.ts"
    },
    "engines": {
        "node": ">=18.0.0"
    },
    "dependencies": {
        "@cucumber/gherkin": "^39.1.0",
        "@cucumber/messages": "^32.3.1",
        "ansi-colors": "^4.1.3",
        "axios": "^1.15.2",
        "form-data": "^4.0.5",
        "semver": "^7.7.3"
    },
    "peerDependencies": {
        "@badeball/cypress-cucumber-preprocessor": ">=17",
        "cypress": ">=10.0.0 < 16"
    },
    "peerDependenciesMeta": {
        "@badeball/cypress-cucumber-preprocessor": {
            "optional": true
        }
    },
    "devDependencies": {
        "@badeball/cypress-cucumber-preprocessor": "^24.0.1",
        "@bahmutov/cypress-esbuild-preprocessor": "^2.2.8",
        "@eslint/js": "^10.0.1",
        "@faker-js/faker": "^10.4.0",
        "@qytera/xray-client": "^4.0.0",
        "@types/node": "^25.6.0",
        "@types/semver": "^7.7.1",
        "c8": "^11.0.0",
        "cypress": "^15.14.1",
        "cypress-on-fix": "^1.1.0",
        "dotenv": "^17.4.2",
        "eslint": "^10.2.1",
        "eslint-plugin-perfectionist": "^5.9.0",
        "eslint-plugin-tsdoc": "^0.5.0",
        "graphql": "^16.13.2",
        "graphql-tag": "^2.12.6",
        "jira.js": "^5.3.1",
        "prettier": "^3.8.3",
        "shx": "^0.4.0",
        "tsx": "^4.21.0",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.59.0"
    }
}
